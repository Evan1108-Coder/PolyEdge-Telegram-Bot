# Telegram (required)
TELEGRAM_BOT_TOKEN=
# Optional: restrict the bot to a single chat / user id (recommended for a private bot)
TELEGRAM_OWNER_ID=

# LLM brain — MiniMax (required)
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M1

# Decision engine tuning
# Minimum edge (fair prob - market prob, in %) before the bot recommends a trade.
EDGE_THRESHOLD=7
# Paper trading starting bankroll (USD)
PAPER_BANKROLL=1000

# Behaviour
DEFAULT_TIMEZONE=Asia/Hong_Kong
LLM_TIMEOUT_MS=60000
